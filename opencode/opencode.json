{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "disabled_providers": [
    "opencode"
  ],
  "share": "disabled",
  "permission": {
    "edit": "ask",
    "webfetch": "ask",
    "doom_loop": "ask",
    "external_directory": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "git status": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "git blame *": "allow",
      "gh pr view *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "ls *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "cat *": "allow"
    }
  },
  "mcp": {},
  "provider": {
    "willard": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Willard's World",
      "options": {
        "baseURL": "http://mac.willard.gay:8080/v1/",
        "apiKey": "{env:WILLARDS_WORLD_INFERENCE_TOKEN}",
        "headers": {}
      },
      "models": {
        "unsloth/GLM-4.7-Flash-GGUF:Q4_K_XL": {
          "name": "unsloth/GLM-4.7-Flash-GGUF:Q4_K_XL"
        },
        "unsloth/GLM-4.7-Flash-GGUF:UD-Q4_K_XL": {
          "name": "unsloth/GLM-4.7-Flash-GGUF:UD-Q4_K_XL"
        },
        "unsloth/Qwen3-Coder-Next-GGUF:Q4_K_XL": {
          "name": "unsloth/Qwen3-Coder-Next-GGUF:Q4_K_XL"
        },
        "unsloth/Qwen3-Coder-Next-GGUF:Q5_K_XL": {
          "name": "unsloth/Qwen3-Coder-Next-GGUF:Q5_K_XL"
        },
        "unsloth/Qwen3-Coder-Next-GGUF:Q8_K_XL": {
          "name": "unsloth/Qwen3-Coder-Next-GGUF:Q8_K_XL"
        },
        "unsloth/Qwen3.6-35B-A3B-GGUF:Q4_K_XL": {
          "name": "unsloth/Qwen3.6-35B-A3B-GGUF:Q4_K_XL"
        },
        "unsloth/Qwen3.6-35B-A3B-GGUF:UD-Q4_K_XL": {
